<!doctype html>
<html>
  <head>
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, shrink-to-fit=no">

    <!-- include system scripts, page meta, and header code injection -->
    {squarespace-headers}
  </head>
  <body id="{squarespace.page-id}" class="{squarespace.page-classes}">

    <div class="site-container">

      <header class="site-header">
        <!-- site navigation -->
        <squarespace:navigation navigationId="siteNav" template="site-navigation" />

      </header>
      <div class=custom-container>
        <h1 class="portfolio-header"> kuwona ventures span diverse industries, delivering impactful solutions rooted in purpose and values.
        </h1>
              <div class="portfolio-list">
                <div class="portfolio-item">
                    <h2 class="portfolio-number">
                    </h2>
                    <div class="details">
                        <h2>
                          <a href="/portfolio/kuwona-digital">
                            <span class="venture-name">01 kuwona digital</span><br>
                          </a>
                            <span class="venture-type">digital solutions & marketing consultancy</span>
                        </h2>
                        <p class="description">crafting thoughtful, tailored strategies that harmonise data-driven insights with human-centred approaches,
                        we ensure accuracy, completeness, and sustainable results. </p>
                    </div>
                </div>
                <div class="portfolio-item">
                    <h2 class="portfolio-number">02
                    </h2>
                    <div class="details">
                    <h2>
                        <span class="venture-name">parabl</span><br>
                        <span class="venture-type">online bookstore</span>
                    </h2>
                        <p class="description">coming soon</p>
                    </div>
                </div>
                <div class="portfolio-item">
                    <h2 class="portfolio-number">03
                    </h2>
                    <div class="details">
                    <h2>
                        <span class="venture-name">my community my people</span><br>
                        <span class="venture-type">a community-powered platform that connects people, ideas, and resources for social change</span>
                    </h2>
                        <p class="description">coming soon</p>
                    </div>
                </div>
              </div>
        </div>
      <!--Footer with open block field -->
      <footer class="site-footer">
          <hr class="horizontal-line">
          <div class="footer-container">
            <div class="newsletter">
              <h3 class=footer-header>newsletter</h3>
              <form class="footer-form">
                <input type="text" placeholder="name" required>
                <input type="email" placeholder="email" required>
                <button type="submit">→</button>
              </form>
            </div>
            <div class="follow">
              <h3 class=footer-header>contact</h3>
              <ul>
                <li>office@kuwonastudios.com</li>
                <li></li>
              </ul>
            </div>
            <div class="legal">
              <h3 class=footer-header>legal</h3>
              <ul>
                <li>privacy policy</li>
                <li>terms & conditions</li>
              </ul>
            </div>
          </div>
    <div class="footer-bottom">
      © kuwona studios 2024
    </div>
  </div>
        <squarespace:block-field id="footerBlocks" columns="12" />
      </footer>

    </div>

    <!-- combo and minify scripts when not logged in -->
    <squarespace:script src="site.js" combo="{.if authenticatedAccount}false{.or}true{.end}" />

    <!-- other scripts, and footer code injection -->
    {squarespace-footers}

  </body>
</html>
