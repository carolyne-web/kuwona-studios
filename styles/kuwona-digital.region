<!doctype html>
<html>
  <head>
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, shrink-to-fit=no">

    <!-- include system scripts, page meta, and header code injection -->
    {squarespace-headers}
  </head>
  <body id="{squarespace.page-id}" class="{squarespace.page-classes}">

    <div class="site-container">

      <header class="site-header">
        <!-- site navigation -->
        <squarespace:navigation navigationId="siteNav" template="site-navigation" />

      </header>
      <div class="venture-container">
        <h1 class="venture-header"> crafting thoughtful, <span class=bird>tailored strategies</span> that harmonize data-driven insights with
        creative human-centered approaches, we ensure accuracy, completeness, and sustainable results.
        </h1>
        <p>
        we specialise in helping brands, big and small, distinguish themselves in today's highly saturated market, and
        make it easier for them to navigate the complexities of the digital landscape. our goal is simple: to make your
        brand memorable, recognizable, profitable, and impactful.
        </p>
        <p>with our expert guidance and personalised approach, you'll gain the clarity and confidence needed to achieve
        your marketing and digital objectives. trust our consultancy to be the extra eye that sees what others miss and the
        partner that helps you stand out in a crowded marketplace.
        </p>
        <p>
        </p>
        <div>
        <!-- cms content injection point -->
        <main class="content-container" role="main" data-content-field="main-content">
        {squarespace.main-content}
        test
        </main>
        <img src="/cabal_logo.png">
        </div>
      </div>

      <!--Footer with open block field -->
      <footer class="site-footer">
          <hr class="horizontal-line">
          <div class="footer-container">
            <div class="newsletter">
              <h3 class=footer-header>subscribe to our newsletter for insights</h3>
              <form class="footer-form">
                <input type="text" placeholder="name" required>
                <input type="email" placeholder="email" required>
                <button type="submit">→</button>
              </form>
            </div>
            <div class="follow">
              <h3 class=footer-header>follow</h3>
              <ul>
                <li>instagram</li>
                <li>x</li>
              </ul>
            </div>
            <div class="legal">
              <h3 class=footer-header>legal</h3>
              <ul>
                <li>privacy policy</li>
                <li>terms & conditions</li>
              </ul>
            </div>
          </div>
    <div class="footer-bottom">
      © kuwona studios 2024
    </div>
  </div>
        <squarespace:block-field id="footerBlocks" columns="12" />
      </footer>

    </div>

    <!-- combo and minify scripts when not logged in -->
    <squarespace:script src="site.js" combo="{.if authenticatedAccount}false{.or}true{.end}" />
    <squarespace:script src="boldFadeIn.js" />
    <!-- other scripts, and footer code injection -->
    {squarespace-footers}
  </body>
</html>
