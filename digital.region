<!doctype html>
<html>
  <head>
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, shrink-to-fit=no">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Public+Sans:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://use.typekit.net/wmi0wxx.css">
    <!-- include system scripts, page meta, and header code injection -->
    {squarespace-headers}
  </head>
  <body id="{squarespace.page-id}" class="{squarespace.page-classes}">

    <div class="digital-container">

      <header class="digital-header">
        <!-- site navigation -->
        <squarespace:navigation navigationId="digitalNav" template="digital-navigation" />
        <squarespace:navigation navigationId="stickylNav" template="sticky-bottom-navigation" />
      </header>
      <div id="digital-hero-section">
        <h1>
        A Creative studio specialising in <span style="color: #5D686C"> bespoke digital solutions.</span>
        </h1>
        <hr class="digital-divider">
      </div>
      <div id= "digital-services-section">
        <h1>
        what we do
        </h1>
        <div class="cards-container">
          <div class="card card-1 digital-accent-text">
            <span class="card-heading"> design </span>
            <ul class="card-list">
              <li>
              Web Development
              </li>
              <li>
              UI/UX Design
              </li>
              <li>
              Brand strategy
              </li>
            </ul>
          </div>
          <div class="card card-2 digital-accent-text">
            <span class= "card-heading">
            communication
            </span>
            <ul class="card-list">
              <li>
              SEO
              </li>
              <li>
              GOOGLE ADS
              </li>
              <li>
              Email Marketing
              </li>
              <li>
              Copywriting
              </li>
            </ul>
          </div>
          <div class="card card-3 digital-accent-text">
            <span class= "card-heading">
            innovation
            </span>
            <ul class="card-list">
              <li>
              Digital Product Design
              </li>
              <li>
              Consulting
              </li>
              <li>
              Product Development
              </li>
            </ul>
          </div>
        </div>
        <div class="digital-services-cta">
          <p class= "digital-accent-text">
            Our goal is simple: to make your brand memorable, recognisable, profitable, and impactful. VIEW ALL
          </p>
        </div>
        <div>
          <hr class="digital-divider">
        </div>
      </div>
      <div id= "digital-featured-work-section">
        <h1>
          featured work
        </h1>
        cabal . digital . sanic . mzansi . heaven spaces . out of south africa
      </div>
      <div id= "digital-insights-section">
        <div class="digital-insights-sub">
          <div class= "blog-1">
          </div>
          <div class="digital-insights-header">
            <h1>
            insights
            </h1>
          </div>
        </div>
        <div class="digital-insights-sub">
          <div class="blog-2">
          </div>
          <div class="blog-3">
          </div>
        </div>
      </div>
      <div id= "digital-contact-section">
        <h1>
          lets have a conversation
        </h1>
        <p>
          schedule a call
        </p>
        <p>
          email us at digital@kuwonastudios.com
        </p>
        <div class="digital-footer">
          <p>
            kuwona digital © 2024
          </p>
          <p>
            Cape Town, South africa
          </p>
        </div>
      </div>
    </div>

    <!-- combo and minify scripts when not logged in -->
    <squarespace:script src="site.js" combo="{.if authenticatedAccount}false{.or}true{.end}" />
    <squarespace:script src="boldFadeIn.js" />
    <squarespace:script src="navigation.js"/>
    <squarespace:script src="newsletter-form.js"/>
    <!-- other scripts, and footer code injection -->
    {squarespace-footers}
  </body>
</html>
