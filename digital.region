<!doctype html>
<html>
  <head>
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, shrink-to-fit=no">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Public+Sans:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Mono:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://use.typekit.net/wmi0wxx.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&display=swap" rel="stylesheet">
    <!-- include system scripts, page meta, and header code injection -->
    {squarespace-headers}
  </head>
  <body id="{squarespace.page-id}" class="{squarespace.page-classes}">
    <squarespace:navigation navigationId="stickylNav" template="sticky-bottom-navigation" />
    <div class="digital-container">
      <div id="digital-hero-section">
        <div class="content">
          <header class="digital-header">
        <!-- site navigation -->
        <squarespace:navigation navigationId="digitalNav" template="digital-navigation" />
          </header>
          <h1>
          <span class="hero-header"> Turning Ideas into </span> <span class="emph"> Great Brands </span> <span class="hero-header"> & </span> <br> <span class="emph">Unique Digital Experiences</span>
          </h1>
        </div>
      </div>
      <div id= "digital-services-section">
        <h1>
        What We Do
        </h1>
        <div class="cards-container">
          <div class="card card-1 digital-accent-text">
            <div class="card-title">
              <span class= "card-heading"> Strategy & Positioning: </span> <br><br> <span class= "card-sub-heading">Defining and implementing strategies
              to position a brand effectively in the market.</span>
            </div>
            <ul class="card-list">
              <li>
              Copywriting
              </li>
              <li>
              Exploration & Research
              </li>
              <li>
              Brand Positioning
              </li>
              <li>
              Brand Voice
              </li>
            </ul>
          </div>
          <div class="card card-2 digital-accent-text">
            <div class="card-title">
              <span class= "card-heading"> Branding & Communication: </span> <br><br> <span class= "card-sub-heading"> Creating and managing
              a brand's visual and verbal identity to commincaite effectively with the target audience.
              </span>
            </div>
            <ul class="card-list">
              <li>
              Visual Storytelling
              </li>
              <li>
              Visual Brand Identity
              </li>
              <li>
              Creative direction
              </li>
            </ul>
          </div>
          <div class="card card-3 digital-accent-text">
            <div class="card-title">
              <span class= "card-heading"> Digital Products & Experiences: </span> <br><br> <span class= "card-sub-heading">
              Creation and optimization of digital solutions that enhance user engagement and functionality.
              </span>
            </div>
            <ul class="card-list">
              <li>
              Web Design
              </li>
              <li>
              UX/ UI Design
              </li>
              <li>
              Web Development
              </li>
              <li>
              E-Commerce
              </li>
            </ul>
          </div>
        </div>
      </div>
      <div id= "digital-featured-work-section">
        <ul class="client-list">
          <li><img src="assets/fonts/images/cabal_logo_digital.png" alt="Cabal Bikes Logo"></li>
          <li><img src="assets/fonts/images/sanic_logo_digital.png" alt="SANIC Clean Logo"></li>
          <li><img src="assets/fonts/images/the_digital_collar_logo_digital.png" alt="The Digital Collar Logo"></li>
          <li><img src="assets/fonts/images/mzansi_logo_digital.png" alt="Mzansi Books Logo"></li>
        </ul>
      </div>
      <div>
          <hr class="digital-divider">
        </div>
      </div>
      <div class="digital-services-cta">
        <p class= "digital-accent-text">
          Our goal is simple: to make your brand memorable, recognisable, profitable, and impactful. VIEW ALL
        </p>
      </div>
      <div id= "digital-insights-section">
        <div class="digital-insights-sub">
          <div class= "blog-1">
          </div>
          <div class="digital-insights-header">
            <h1>
            insights
            </h1>
          </div>
        </div>
        <div class="digital-insights-sub">
          <div class="blog-2">
          </div>
          <div class="blog-3">
          </div>
        </div>
      </div>
      <div id= "digital-contact-section">
        <h1>
          lets have a conversation
        </h1>
        <p>
          schedule a call
        </p>
        <p>
          email us at digital@kuwonastudios.com
        </p>
        <div class="digital-footer">
          <p>
            kuwona digital © 2024
          </p>
          <p>
            Cape Town, South africa
          </p>
        </div>
      </div>
    </div>
    <!-- combo and minify scripts when not logged in -->
    <squarespace:script src="site.js" combo="{.if authenticatedAccount}false{.or}true{.end}" />
    <squarespace:script src="boldFadeIn.js" />
    <squarespace:script src="navigation.js"/>
    <squarespace:script src="newsletter-form.js"/>
    <!-- other scripts, and footer code injection -->
    {squarespace-footers}
  </body>
</html>
