<!doctype html>
<html>
  <head>
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, shrink-to-fit=no">

    <!-- include system scripts, page meta, and header code injection -->
    {squarespace-headers}
  </head>
  <body id="{squarespace.page-id}" class="{squarespace.page-classes}">

    <div class="site-container">

      <header class="site-header">
        <!-- site navigation -->
        <squarespace:navigation navigationId="siteNav" template="site-navigation" />

      </header>
      <div class=custom-container>
        <h1 class="page-header"> about
        </h1>
        <p>
          At Kuwona Studios, we are guided by the belief that empowering the right ideas has the power to heal the world.
          Driven by our core values of <span class="core-value">compassion</span>, <span class="core-value">integrity</span>,
          <span class="core-value">boldness</span>, <span class="core-value">curiosity</span>, <span class="core-value">originality</span>
          and <span class="core-value">sustainability</span>,
          we strive to create and empower ventures across industries that embody these principles and reflect our vision of a better world.
          Through our unwavering commitment, we aim to make a lasting impact that resonates for generations to come.
        </p>
        <h2 class="page-subheader"> meet the founders <h2>
        <a href="/portfolio" class="explore-link"> explore our ventures </a>
      </div>
      <!--Footer with open block field -->
      <footer class="site-footer">
          <hr class="horizontal-line">
          <div class="footer-container">
            <div class="newsletter">
              <h3 class=footer-header>newsletter</h3>
                <p>subscribe for insights</p>
              <form>
                <input type="text" placeholder="name" required>
                <input type="email" placeholder="email" required>
                <button type="submit">→</button>
              </form>
            </div>
            <div class="follow">
              <h3 class=footer-header>follow</h3>
              <ul>
                <li>instagram</li>
                <li>x</li>
                <li>tiktok</li>
              </ul>
            </div>
            <div class="legal">
              <h3 class=footer-header>legal</h3>
              <ul>
                <li>privacy policy</li>
                <li>terms & conditions</li>
              </ul>
            </div>
          </div>
    <div class="footer-bottom">
      © kuwona studios 2024
    </div>
  </div>
        <squarespace:block-field id="footerBlocks" columns="12" />
      </footer>

    </div>

    <!-- combo and minify scripts when not logged in -->
    <squarespace:script src="site.js" combo="{.if authenticatedAccount}false{.or}true{.end}" />

    <!-- other scripts, and footer code injection -->
    {squarespace-footers}

  </body>
</html>
